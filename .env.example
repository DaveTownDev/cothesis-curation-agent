# Copy to .env (gitignored). Real values go in Secret Manager at deploy, never here.

# Google Cloud — auth via `gcloud auth application-default login` (ADC)
GOOGLE_CLOUD_PROJECT=cothesis-curation-agent
GOOGLE_CLOUD_LOCATION=global          # Gemini 3.x is global-endpoint only
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Vertex AI Search grounding datastore (full ID from the console)
VERTEX_DATASTORE_ID=projects/PROJECT/locations/global/collections/default_collection/dataStores/DATASTORE_ID

# Models — verified on Vertex AI global endpoint; update when Gemini 3 releases
MODEL_FLASH_LITE=gemini-3.1-flash-lite
MODEL_FLASH=gemini-3.5-flash
MODEL_PRO=gemini-3.1-pro-preview

# Routing-gate thresholds (calibrated baseline)
IMPORT_RELEVANCE_AUTO_ACCEPT=0.6
IMPORT_RELEVANCE_AUTO_EXCLUDE=0.3
IMPORT_CONFIDENCE_AUTO_ACCEPT=0.8
IMPORT_CONFIDENCE_REVIEW=0.5
IMPORT_TITLE_SIMILARITY_THRESHOLD=0.9

# External services — placeholders only; real values in Secret Manager
CONTEXT7_API_KEY=your_key_here
MCP_SERVER_URL=your_public_mcp_hostname_here
MCP_SERVER_KEY=your_scoped_key_here
CONSOLE_LOGIN_SECRET=your_judge_passcode_here
CONSOLE_PUBLIC_URL=https://your-console-url.run.app
