        "Data dictionary"
      ],
      "secondary_deliverables": [
        "Coding manual",
        "Measurement validation evidence"
      ],
      "success_criteria": [
        "All key constructs operationalized",
        "Measurement validity addressed",
        "Definitions are unambiguous"
      ],
      "common_blockers": [
