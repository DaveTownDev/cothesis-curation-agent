{
  "_schema": {
    "name": "CoThesis THESIS Framework - Phases & Core Stages",
    "version": "1.0.0",
    "description": "6 THESIS phases with 25 universal core stages, designed for methodology-specific overrides and inserts",
    "entities": {
      "phase": {
        "phase_id": "string - Unique identifier (e.g., 'PHASE-T')",
        "code": "string - Single letter code (T, H, E, S, I, S2)",
        "name": "string - Short name",
        "full_name": "string - Full descriptive name",
        "description": "string - Phase purpose",
        "sequence": "number - Order (1-6)",
        "typical_duration_percent": "number - Percentage of total project time"
      },
      "core_stage": {
        "stage_id": "string - Unique identifier (e.g., 'STG-T-01')",
        "phase_id": "string - Parent phase reference",
        "code": "string - Stage code (e.g., 'T-01')",
        "sequence_in_phase": "number - Order within phase (1-5)",
        "global_sequence": "number - Order across all phases (1-25)",
        "name": "string - Generic stage name",
        "description": "string - Generic stage description",
        "purpose": "string - Why this stage exists",
        "stage_type": "'CORE' - Always CORE for base stages",
        "is_universal": "boolean - true = required for ALL methodologies",
        "typical_duration": "object - { min, typical, max, unit }",
        "primary_deliverables": "string[] - Main outputs",
        "secondary_deliverables": "string[] | null - Optional outputs",
        "success_criteria": "string[] - How to know stage is complete",
        "common_blockers": "string[] - What typically delays this stage"
      }
    },
    "progression_actions": [
      "NEXT - Move to next stage in sequence",
      "SKIP_TO - Jump forward to specific stage",
      "REPEAT - Start current stage over",
      "GO_BACK_ONE - Return to previous stage",
      "GO_BACK_TO - Return to specific earlier stage (loop)",
      "BRANCH - Start parallel track",
      "COMPLETE_PHASE - Mark phase complete",
      "COMPLETE_PROJECT - Project finished"
    ],
    "progression_triggers": [
      "DECISION_POINT - Based on decision point outcome",
      "STAGE_OUTCOME - Based on how stage completed",
      "PROJECT_STATE - Based on project status",
      "DELIVERABLE_STATUS - Based on deliverable completion",
      "TIME_ELAPSED - Based on duration",
      "EXTERNAL_EVENT - Ethics rejection, etc.",
      "USER_CHOICE - Manual selection"
    ],
    "counts": {
      "phases": 6,
      "core_stages": 25,
      "stages_per_phase": {
        "T": 4,
        "H": 4,
        "E": 5,
        "S": 4,
        "I": 4,
        "S2": 4
      }
    }
  },

  "phases": [
    {
      "phase_id": "PHASE-T",
      "code": "T",
      "name": "Theory",
      "full_name": "Theory: Research Question Development",
      "description": "Developing and refining the research question, identifying gaps in knowledge, and establishing theoretical foundations",
      "sequence": 1,
      "typical_duration_percent": 10
    },
    {
      "phase_id": "PHASE-H",
      "code": "H",
      "name": "History",
      "full_name": "History: Literature Review & Context",
      "description": "Comprehensive evidence gathering, critical appraisal, and establishing context for the study",
      "sequence": 2,
      "typical_duration_percent": 15
    },
    {
      "phase_id": "PHASE-E",
      "code": "E",
      "name": "Evaluate",
      "full_name": "Evaluate: Study Design & Ethics",
      "description": "Methodology selection, protocol development, and obtaining necessary approvals",
      "sequence": 3,
      "typical_duration_percent": 20
    },
    {
      "phase_id": "PHASE-S",
      "code": "S",
      "name": "Study",
      "full_name": "Study: Data Collection & Management",
      "description": "Data acquisition, quality control, and data management",
      "sequence": 4,
      "typical_duration_percent": 25
    },
    {
      "phase_id": "PHASE-I",
      "code": "I",
      "name": "Interpret",
      "full_name": "Interpret: Analysis & Results",
      "description": "Data analysis, results interpretation, and robustness testing",
      "sequence": 5,
      "typical_duration_percent": 15
    },
    {
      "phase_id": "PHASE-S2",
      "code": "S2",
      "name": "Share",
      "full_name": "Share: Writing & Dissemination",
      "description": "Manuscript preparation, revision, submission, and dissemination",
      "sequence": 6,
      "typical_duration_percent": 15
    }
  ],

  "core_stages": [
    {
      "stage_id": "STG-T-01",
      "phase_id": "PHASE-T",
      "code": "T-01",
      "sequence_in_phase": 1,
      "global_sequence": 1,
      "name": "Topic Identification & Scoping",
      "description": "Identify research area of interest, assess scope, and explore initial feasibility based on available resources and context",
      "purpose": "Establishes the broad direction of the research project before narrowing to specific questions",
      "stage_type": "CORE",
      "is_universal": true,
      "typical_duration": {
        "min": 1,
        "typical": 2,
        "max": 4,
        "unit": "weeks"
      },
      "primary_deliverables": [
        "Research topic statement",
        "Initial scope definition",
        "Preliminary feasibility notes"
      ],
      "secondary_deliverables": [
        "Supervisor discussion notes",
        "Initial reading list"
      ],
      "success_criteria": [
        "Topic area clearly articulated",
        "Scope appropriately bounded for available resources",
        "Supervisor agreement on direction"
      ],
      "common_blockers": [
        "Topic too broad or too narrow",
        "Lack of supervisor alignment",
        "Unclear personal interest or motivation"
      ]
    },
    {
      "stage_id": "STG-T-02",
      "phase_id": "PHASE-T",
      "code": "T-02",
      "sequence_in_phase": 2,
      "global_sequence": 2,
      "name": "Question/Aim Formulation",
      "description": "Develop focused research question(s) or study aims using appropriate frameworks (PICO, SPIDER, PEO, etc.)",
      "purpose": "Creates a clear, answerable research question that guides the entire study design",
      "stage_type": "CORE",
      "is_universal": true,
      "typical_duration": {
        "min": 1,
        "typical": 2,
        "max": 3,
        "unit": "weeks"
      },
      "primary_deliverables": [
        "Primary research question/aim",
        "Secondary questions/aims (if applicable)",
        "Framework application (PICO/SPIDER/etc.)"
      ],
      "secondary_deliverables": [
        "Question evolution documentation",
        "Alternative questions considered"
      ],
      "success_criteria": [
        "Question is specific and answerable",
        "Framework elements clearly defined",
        "Question aligned with feasibility constraints"
      ],
      "common_blockers": [
        "Question too vague or complex",
        "Misalignment between question and available data/methods",
        "Scope creep from original topic"
      ]
    },
    {
      "stage_id": "STG-T-03",
      "phase_id": "PHASE-T",
      "code": "T-03",
      "sequence_in_phase": 3,
      "global_sequence": 3,
      "name": "Theoretical Framing",
      "description": "Establish theoretical basis for the study: hypotheses for quantitative work, conceptual frameworks, guiding theories, or methodological positioning for qualitative work",
      "purpose": "Provides the intellectual foundation and expected relationships that guide study design and interpretation",
      "stage_type": "CORE",
      "is_universal": true,
      "typical_duration": {
        "min": 1,
        "typical": 2,
        "max": 4,
        "unit": "weeks"
      },
      "primary_deliverables": [
        "Hypotheses OR conceptual framework OR theoretical positioning",
        "Expected relationships/outcomes",
        "Justification for theoretical approach"
      ],
      "secondary_deliverables": [
        "Conceptual diagram",
        "Theory sources and references"
      ],
      "success_criteria": [
        "Clear theoretical basis articulated",
        "Alignment between theory and research question",
        "Testable predictions or clear interpretive lens"
      ],
      "common_blockers": [
        "Difficulty selecting appropriate theory",
        "Mismatch between theory and methodology",
        "Over-complex theoretical frameworks"
      ]
    },
    {
      "stage_id": "STG-T-04",
      "phase_id": "PHASE-T",
      "code": "T-04",
      "sequence_in_phase": 4,
      "global_sequence": 4,
      "name": "Feasibility Assessment",
      "description": "Systematic assessment of resources, timeline, data access, expertise, and overall project viability",
      "purpose": "Ensures the project can realistically be completed within constraints before major investment",
      "stage_type": "CORE",
      "is_universal": true,
      "typical_duration": {
        "min": 0.5,
        "typical": 1,
        "max": 2,
        "unit": "weeks"
      },
      "primary_deliverables": [
        "Feasibility assessment document",
        "Resource requirements list",
        "Preliminary timeline"
      ],
      "secondary_deliverables": [
        "Risk register",
        "Contingency plans"
      ],
      "success_criteria": [
        "All major feasibility dimensions assessed",
        "Go/no-go decision made",
        "Supervisor sign-off on feasibility"
      ],
      "common_blockers": [
        "Unrealistic timeline expectations",
        "Data access not confirmed",
        "Resource gaps identified but not addressed"
      ]
    },
    {
      "stage_id": "STG-H-01",
      "phase_id": "PHASE-H",
      "code": "H-01",
      "sequence_in_phase": 1,
      "global_sequence": 5,
      "name": "Search Strategy Development",
      "description": "Define search approach including databases, search terms, inclusion/exclusion criteria, and documentation method",
      "purpose": "Creates a systematic, reproducible approach to identifying relevant evidence",
      "stage_type": "CORE",
      "is_universal": true,
      "typical_duration": {
        "min": 0.5,
        "typical": 1,
        "max": 2,
        "unit": "weeks"
      },
      "primary_deliverables": [
        "Search strategy document",
        "Database selection with justification",
        "Search terms and syntax"
      ],
      "secondary_deliverables": [
        "Librarian consultation notes",
        "Pilot search results"
      ],
      "success_criteria": [
        "Strategy is systematic and reproducible",
        "Appropriate databases selected for topic",
        "Search tested and refined"
      ],
      "common_blockers": [
        "Too narrow or too broad search",
        "Database access issues",
        "Inadequate indexing/MeSH terms"
      ]
    },
    {
      "stage_id": "STG-H-02",
      "phase_id": "PHASE-H",
      "code": "H-02",
      "sequence_in_phase": 2,
      "global_sequence": 6,
      "name": "Evidence Gathering",
      "description": "Execute search strategy, screen results, and select relevant evidence or literature for inclusion",
      "purpose": "Identifies and retrieves the body of evidence that will inform or constitute the study",
      "stage_type": "CORE",
      "is_universal": true,
      "typical_duration": {
        "min": 1,
        "typical": 3,
        "max": 8,
        "unit": "weeks"
      },
      "primary_deliverables": [
