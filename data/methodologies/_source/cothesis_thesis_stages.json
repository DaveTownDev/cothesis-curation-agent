      ],
      "success_criteria": [
        "All planned databases searched",
        "Screening completed systematically",
        "Included sources retrieved and organised"
      ],
      "common_blockers": [
        "High volume of results",
        "Full-text access issues",
        "Inconsistent screening decisions"
      ]
    },
    {
      "stage_id": "STG-H-03",
      "phase_id": "PHASE-H",
      "code": "H-03",
      "sequence_in_phase": 3,
      "global_sequence": 7,
      "name": "Quality Assessment",
      "description": "Appraise quality of evidence, assess risk of bias, and evaluate strength of included sources",
