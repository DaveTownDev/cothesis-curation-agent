        "No validated measure available",
        "Mismatch between concept and available data"
      ]
    },
    {
      "stage_id": "STG-E-03",
      "phase_id": "PHASE-E",
      "code": "E-03",
      "sequence_in_phase": 3,
      "global_sequence": 11,
      "name": "Sample/Selection Strategy",
      "description": "Determine sampling approach, sample size, selection criteria, and recruitment or selection procedures",
      "purpose": "Defines who/what will be studied and how they will be identified and included",
      "stage_type": "CORE",
      "is_universal": true,
      "typical_duration": {
        "min": 1,
        "typical": 2,
        "max": 4,
        "unit": "weeks"
      },
      "primary_deliverables": [
        "Inclusion/exclusion criteria",
        "Sample size justification",
        "Sampling/selection procedure"
      ],
      "secondary_deliverables": [
        "Power calculation (if applicable)",
        "Recruitment materials"
      ],
      "success_criteria": [
