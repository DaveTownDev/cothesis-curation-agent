      "is_universal": true,
      "typical_duration": {
        "min": 1,
        "typical": 2,
        "max": 4,
        "unit": "weeks"
      },
      "primary_deliverables": [
        "Quality/risk of bias assessments",
        "Evidence quality summary",
        "Assessment tool selection and justification"
      ],
      "secondary_deliverables": [
        "Quality assessment training records",
        "Inter-rater agreement (if dual assessment)"
      ],
      "success_criteria": [
        "Appropriate assessment tool selected",
        "All included sources assessed",
        "Quality limitations documented"
      ],
      "common_blockers": [
        "Selecting inappropriate appraisal tool",
        "Inconsistency between assessors",
        "Studies with missing information"
      ]
    },
    {
      "stage_id": "STG-H-04",
      "phase_id": "PHASE-H",
      "code": "H-04",
      "sequence_in_phase": 4,
      "global_sequence": 8,
      "name": "Synthesis & Positioning",
      "description": "Synthesise findings from gathered evidence, identify gaps, and position current study within existing knowledge",
      "purpose": "Establishes what is known, what is unknown, and why the current study is needed",
      "stage_type": "CORE",
      "is_universal": true,
      "typical_duration": {
        "min": 1,
        "typical": 2,
        "max": 4,
        "unit": "weeks"
      },
      "primary_deliverables": [
        "Literature synthesis/narrative",
        "Gap identification",
        "Study justification"
      ],
      "secondary_deliverables": [
        "Evidence tables",
        "Conceptual map of literature"
      ],
      "success_criteria": [
        "Clear synthesis of current evidence",
        "Gap clearly articulated",
        "Study rationale well-supported"
      ],
      "common_blockers": [
        "Difficulty synthesising heterogeneous evidence",
        "Gap already addressed by recent publication",
        "Weak link between gap and proposed study"
      ]
    },
    {
      "stage_id": "STG-E-01",
      "phase_id": "PHASE-E",
      "code": "E-01",
      "sequence_in_phase": 1,
      "global_sequence": 9,
      "name": "Study Design Specification",
      "description": "Define methodology, design type, and core study parameters",
      "purpose": "Establishes the methodological approach that will answer the research question",
      "stage_type": "CORE",
      "is_universal": true,
      "typical_duration": {
        "min": 1,
        "typical": 2,
        "max": 4,
        "unit": "weeks"
      },
      "primary_deliverables": [
        "Study design document",
        "Methodology justification",
        "Design parameters specification"
      ],
      "secondary_deliverables": [
        "Alternative designs considered",
        "Design limitations acknowledged"
      ],
      "success_criteria": [
        "Design matches research question",
        "Design is feasible within constraints",
        "Methodology clearly specified"
      ],
      "common_blockers": [
