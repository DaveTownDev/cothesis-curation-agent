        "Overly restrictive criteria",
        "Power calculation errors"
      ]
    },
    {
      "stage_id": "STG-E-04",
      "phase_id": "PHASE-E",
      "code": "E-04",
      "sequence_in_phase": 4,
      "global_sequence": 12,
