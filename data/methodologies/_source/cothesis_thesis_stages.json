        "Unfamiliarity with chosen methodology"
      ]
    },
    {
      "stage_id": "STG-E-02",
      "phase_id": "PHASE-E",
      "code": "E-02",
      "sequence_in_phase": 2,
      "global_sequence": 10,
      "name": "Construct Operationalization",
