# Benchmark image for the Cloud Run Job `run-benchmark`.
# Runs scripts.run_benchmark (pytest → adk eval → eval-summary.json).
FROM python:3.12-slim

WORKDIR /app
ENV PYTHONUNBUFFERED=1 PYTHONDONTWRITEBYTECODE=1

COPY agents/requirements.txt /app/agents/requirements.txt
RUN pip install --no-cache-dir "google-adk>=2.1.0,<2.2.0" -r /app/agents/requirements.txt

COPY . /app

ENTRYPOINT ["python", "-m", "scripts.run_benchmark"]
